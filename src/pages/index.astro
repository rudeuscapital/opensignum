---
import Base from '../layouts/Base.astro';
import {
  fetchMultipleCryptoTickers, fetchForexTicker, fetchCryptoOHLC,
  computeRSI, computeMACD, computeBollinger, computeEMA,
  formatPrice, formatVolume,
  type Ticker, type CandleData,
} from '../lib/api';

const session = (Astro.locals as any).session;
const appHref = session ? '/app' : '/auth/login';

// ── Fetch real market data server-side ──────────────────────────────────────
const cryptoSyms = ['BTC','ETH','SOL','BNB','XRP','ADA','DOGE','AVAX','DOT','LINK'];
const [cryptoRes, eurRes, gbpRes, ohlcRes, globalRes] = await Promise.allSettled([
  fetchMultipleCryptoTickers(cryptoSyms),
  fetchForexTicker('EUR/USD'),
  fetchForexTicker('GBP/USD'),
  fetchCryptoOHLC('BTC', 30),
  fetch('https://api.coingecko.com/api/v3/global').then(r => r.json()),
]);

const cryptoTickers: Ticker[] = cryptoRes.status === 'fulfilled' ? cryptoRes.value : [];
const forexTickers: Ticker[] = [
  ...(eurRes.status === 'fulfilled' ? [eurRes.value] : []),
  ...(gbpRes.status === 'fulfilled' ? [gbpRes.value] : []),
];
const allTickers = [...cryptoTickers, ...forexTickers];
const btcOhlc: CandleData[] = ohlcRes.status === 'fulfilled' ? ohlcRes.value : [];
const btc = cryptoTickers.find(t => t.symbol === 'BTC');

// Global market stats
const globalData = globalRes.status === 'fulfilled' ? globalRes.value.data : null;
const totalMarketCap = globalData?.total_market_cap?.usd ?? 0;
const totalVolume24h = globalData?.total_volume?.usd ?? 0;
const btcDominance = globalData?.market_cap_percentage?.btc ?? 0;

// ── Compute real BTC indicators ─────────────────────────────────────────────
const closes = btcOhlc.map(c => c.close);
const rsi = closes.length > 14 ? computeRSI(closes) : 50;
const macd = computeMACD(closes);
const bb = computeBollinger(closes);
const ema20arr = closes.length > 20 ? computeEMA(closes, 20) : [];
const ema20val = ema20arr.length > 0 ? ema20arr[ema20arr.length - 1] : (btc?.price ?? 0);

// ── Generate SVG paths from real OHLC data ──────────────────────────────────
function toSvgPath(values: number[], w = 660, h = 160, pad = 10): string {
  if (values.length < 2) return `M0,${h/2} L${w},${h/2}`;
  const mn = Math.min(...values), mx = Math.max(...values), rng = mx - mn || 1;
  return values.map((v, i) => {
    const x = (i / (values.length - 1)) * w;
    const y = pad + ((mx - v) / rng) * (h - 2 * pad);
    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
}

const chartPath = toSvgPath(closes);
// Bollinger band paths (last 20 candles projected across full width)
const bbUpper = closes.length >= 20
  ? toSvgPath(closes.map((_, i) => {
      const slice = closes.slice(Math.max(0, i - 19), i + 1);
      if (slice.length < 2) return closes[i];
      const mean = slice.reduce((a, b) => a + b, 0) / slice.length;
      const std = Math.sqrt(slice.reduce((s, v) => s + (v - mean) ** 2, 0) / slice.length);
      return mean + 2 * std;
    }))
  : '';
const bbLower = closes.length >= 20
  ? toSvgPath(closes.map((_, i) => {
      const slice = closes.slice(Math.max(0, i - 19), i + 1);
      if (slice.length < 2) return closes[i];
      const mean = slice.reduce((a, b) => a + b, 0) / slice.length;
      const std = Math.sqrt(slice.reduce((s, v) => s + (v - mean) ** 2, 0) / slice.length);
      return mean - 2 * std;
    }))
  : '';
const emaPath = ema20arr.length > 0 ? toSvgPath(ema20arr) : '';

// Last point for the pulsing dot
const lastY = closes.length >= 2
  ? (() => { const mn = Math.min(...closes), mx = Math.max(...closes), rng = mx - mn || 1;
     return 10 + ((mx - closes[closes.length - 1]) / rng) * 140; })()
  : 80;

// ── Ticker marquee data ─────────────────────────────────────────────────────
const marqueeItems = allTickers.map(t => ({
  s: t.symbol,
  p: t.assetClass === 'forex' ? t.price.toFixed(4) : ('$' + formatPrice(t.price)),
  c: `${t.changePct24h >= 0 ? '+' : ''}${t.changePct24h.toFixed(2)}%`,
  up: t.changePct24h >= 0,
  vol: t.volume24h,
  mcap: t.marketCap ?? 0,
}));
// Double for seamless loop
const marqueeDouble = [...marqueeItems, ...marqueeItems];

// BTC display values
const btcPrice = btc ? formatPrice(btc.price) : '—';
const btcChange = btc ? btc.changePct24h : 0;
const btcVolume = btc ? formatVolume(btc.volume24h) : '$0';
const btcUp = btcChange >= 0;
---
<Base title="Open Signum Copilot — AI-Powered Trading Dashboard">

<!-- ═══════════════════════════════════════════════════════════════════════════
     LANDING PAGE STYLES — animations, grid, glow effects
     ═══════════════════════════════════════════════════════════════════════════ -->
<style>
  /* ── Reveal on scroll ─────────────────────────────────────────────────── */
  .reveal{opacity:0;transform:translateY(32px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1)}
  .reveal.visible{opacity:1;transform:translateY(0)}
  .reveal-d1{transition-delay:.1s}.reveal-d2{transition-delay:.2s}.reveal-d3{transition-delay:.3s}
  .reveal-d4{transition-delay:.4s}.reveal-d5{transition-delay:.5s}.reveal-d6{transition-delay:.6s}

  /* ── Hero background grid ─────────────────────────────────────────────── */
  .hero-grid{
    position:absolute;inset:0;overflow:hidden;pointer-events:none;
    background-image:
      linear-gradient(rgba(0,212,170,.04) 1px,transparent 1px),
      linear-gradient(90deg,rgba(0,212,170,.04) 1px,transparent 1px);
    background-size:60px 60px;
    mask-image:radial-gradient(ellipse 70% 60% at 50% 40%,#000 20%,transparent 70%);
    -webkit-mask-image:radial-gradient(ellipse 70% 60% at 50% 40%,#000 20%,transparent 70%);
  }

  /* ── Animated gradient orbs ───────────────────────────────────────────── */
  .orb{position:absolute;border-radius:50%;filter:blur(100px);pointer-events:none;will-change:transform}
  .orb-1{width:600px;height:600px;background:rgba(0,212,170,.08);top:-200px;left:-100px;animation:orbFloat 12s ease-in-out infinite}
  .orb-2{width:500px;height:500px;background:rgba(59,158,255,.07);top:-100px;right:-150px;animation:orbFloat 15s ease-in-out infinite reverse}
  .orb-3{width:400px;height:400px;background:rgba(167,139,250,.06);bottom:-100px;left:40%;animation:orbFloat 18s ease-in-out infinite 3s}
  @keyframes orbFloat{
    0%,100%{transform:translate(0,0) scale(1)}
    33%{transform:translate(30px,-40px) scale(1.05)}
    66%{transform:translate(-20px,30px) scale(.95)}
  }

  /* ── Floating particles ───────────────────────────────────────────────── */
  .particles{position:absolute;inset:0;overflow:hidden;pointer-events:none}
  .particle{
    position:absolute;width:2px;height:2px;background:var(--green);border-radius:50%;
    opacity:0;animation:particleRise linear infinite;
  }
  @keyframes particleRise{
    0%{opacity:0;transform:translateY(0) scale(1)}
    10%{opacity:.6}
    90%{opacity:.6}
    100%{opacity:0;transform:translateY(-800px) scale(0)}
  }

  /* ── Glow pulse on hero heading ───────────────────────────────────────── */
  .hero-glow{
    text-shadow:0 0 80px rgba(0,212,170,.15),0 0 160px rgba(59,158,255,.08);
    animation:heroGlow 4s ease-in-out infinite alternate;
  }
  @keyframes heroGlow{
    0%{text-shadow:0 0 80px rgba(0,212,170,.12),0 0 160px rgba(59,158,255,.06)}
    100%{text-shadow:0 0 120px rgba(0,212,170,.22),0 0 200px rgba(59,158,255,.12)}
  }

  /* ── Animated gradient text ───────────────────────────────────────────── */
  .gradient-text{
    background:linear-gradient(135deg,var(--green),var(--blue),var(--purple),var(--green));
    background-size:300% 300%;
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    animation:gradShift 6s ease infinite;
  }
  @keyframes gradShift{
    0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}
  }

  /* ── Typewriter / terminal line ───────────────────────────────────────── */
  .terminal-line{
    display:inline-block;overflow:hidden;white-space:nowrap;border-right:2px solid var(--green);
    animation:typeWriter 3s steps(36) 1s forwards,blinkCaret .6s step-end infinite;
    max-width:0;
  }
  .terminal-line.visible{max-width:500px}
  @keyframes typeWriter{from{max-width:0}to{max-width:500px}}
  @keyframes blinkCaret{50%{border-color:transparent}}

  /* ── Stat counter ─────────────────────────────────────────────────────── */
  .stat-num{
    font-family:var(--font-mono);font-size:32px;font-weight:700;
    background:linear-gradient(135deg,var(--green),var(--blue));
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  }

  /* ── Feature card ─────────────────────────────────────────────────────── */
  .feat-card{
    position:relative;background:var(--bg2);border:1px solid var(--border);border-radius:14px;
    padding:28px 24px;overflow:hidden;transition:transform .3s,border-color .3s,box-shadow .3s;
  }
  .feat-card:hover{
    transform:translateY(-4px);border-color:var(--border2);
    box-shadow:0 12px 40px rgba(0,0,0,.3),0 0 0 1px rgba(0,212,170,.08);
  }
  .feat-card::before{
    content:'';position:absolute;top:0;left:0;right:0;height:2px;
    background:linear-gradient(90deg,transparent,var(--green),transparent);
    opacity:0;transition:opacity .3s;
  }
  .feat-card:hover::before{opacity:1}
  .feat-icon{
    width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;
    margin-bottom:16px;position:relative;
  }
  .feat-icon::after{
    content:'';position:absolute;inset:-4px;border-radius:14px;
    opacity:0;transition:opacity .3s;filter:blur(12px);
  }
  .feat-card:hover .feat-icon::after{opacity:.4}

  /* ── Animated chart line (SVG) ────────────────────────────────────────── */
  .chart-line{stroke-dasharray:800;stroke-dashoffset:800;animation:drawLine 3s ease forwards}
  .chart-line.visible{stroke-dashoffset:0}
  @keyframes drawLine{to{stroke-dashoffset:0}}

  /* ── Marquee / ticker ─────────────────────────────────────────────────── */
  .marquee-track{display:flex;gap:32px;animation:marquee 30s linear infinite;width:max-content}
  @keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  /* ── Glowing CTA button ───────────────────────────────────────────────── */
  .cta-btn{
    position:relative;display:inline-flex;align-items:center;gap:10px;
    padding:16px 36px;border-radius:12px;font-size:16px;font-weight:700;
    text-decoration:none;color:#000;overflow:hidden;
    background:linear-gradient(135deg,var(--green),#00e6b8,var(--blue));
    background-size:200% 200%;animation:ctaShift 4s ease infinite;
    transition:transform .2s,box-shadow .2s;
  }
  .cta-btn:hover{transform:translateY(-2px);box-shadow:0 0 30px rgba(0,212,170,.35),0 0 60px rgba(0,212,170,.15)}
  @keyframes ctaShift{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
  .cta-btn::before{
    content:'';position:absolute;inset:0;
    background:linear-gradient(135deg,transparent 40%,rgba(255,255,255,.2) 50%,transparent 60%);
    background-size:250% 100%;animation:shimmer 3s linear infinite;
  }
  @keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

  /* ── Connector lines between sections ─────────────────────────────────── */
  .section-connector{
    width:1px;height:80px;margin:0 auto;
    background:linear-gradient(to bottom,var(--border),var(--green),var(--border));
    opacity:.3;position:relative;
  }
  .section-connector::after{
    content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);
    width:6px;height:6px;border-radius:50%;background:var(--green);
    box-shadow:0 0 10px var(--green);
  }

  /* ── How it works step ────────────────────────────────────────────────── */
  .step-card{
    position:relative;background:var(--bg2);border:1px solid var(--border);border-radius:12px;
    padding:24px 20px;text-align:center;transition:border-color .3s;
  }
  .step-card:hover{border-color:var(--green)}
  .step-num{
    width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;
    font-family:var(--font-mono);font-weight:700;font-size:16px;margin:0 auto 14px;
    border:2px solid var(--green);color:var(--green);
    box-shadow:0 0 20px rgba(0,212,170,.1);
  }
  .step-connector{
    position:absolute;top:44px;left:100%;width:calc(100% - 40px);height:2px;
    background:linear-gradient(90deg,var(--green),transparent);
    opacity:.2;pointer-events:none;
  }

  /* ── Testimonial / social proof ───────────────────────────────────────── */
  .proof-card{
    background:var(--bg2);border:1px solid var(--border);border-radius:12px;
    padding:20px 24px;position:relative;
  }
  .proof-card::before{
    content:'"';position:absolute;top:12px;left:16px;
    font-size:48px;line-height:1;color:var(--border2);font-family:serif;
  }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media(max-width:768px){
    .feat-grid{grid-template-columns:1fr!important}
    .steps-grid{grid-template-columns:1fr!important}
    .stats-grid{grid-template-columns:repeat(2,1fr)!important}
    .proof-grid{grid-template-columns:1fr!important}
    .more-feat-grid{grid-template-columns:1fr!important}
    .token-utility-grid{grid-template-columns:1fr!important}
    .token-phase-grid{grid-template-columns:repeat(2,1fr)!important}
    .step-connector{display:none}
    .hero-h1{font-size:28px!important}
    .roadmap-item{flex-direction:column!important}
    .roadmap-item>div:first-child{width:100%!important;text-align:left!important;padding:0!important}
    .roadmap-center-dot{display:none!important}
    .roadmap-spacer{display:none!important}
    .roadmap-line{left:16px!important}
  }
  @media(max-width:480px){
    .hero-h1{font-size:24px!important}
    .token-phase-grid{grid-template-columns:1fr!important}
    .stats-grid{grid-template-columns:1fr 1fr!important;gap:12px!important}
  }
</style>

<!-- ═══════════════════════════════════════════════════════════════════════════
     NAVBAR — glassmorphism
     ═══════════════════════════════════════════════════════════════════════════ -->
<nav class="landing-nav" style="position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:0 32px;height:60px;background:rgba(8,12,16,.75);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid rgba(30,42,54,.6);">
  <div style="display:flex;align-items:center;gap:10px;">
    <img src="/logo.png" alt="Open Signum" style="width:34px;height:34px;border-radius:8px;object-fit:contain;" />
    <span style="font-family:var(--font-mono);font-size:14px;font-weight:700;letter-spacing:.06em;">OPEN SIGNUM</span>
  </div>
  <div class="landing-nav-links" style="display:flex;align-items:center;gap:24px;">
    <a href="#features" style="font-size:13px;color:var(--text2);text-decoration:none;transition:color .2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text2)'">Features</a>
    <a href="#how-it-works" style="font-size:13px;color:var(--text2);text-decoration:none;transition:color .2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text2)'">How It Works</a>
    <a href="/docs" style="font-size:13px;color:var(--text2);text-decoration:none;transition:color .2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text2)'">Docs</a>
    <a href="#roadmap" style="font-size:13px;color:var(--text2);text-decoration:none;transition:color .2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text2)'">Roadmap</a>
    <a href="#token" style="font-size:13px;color:var(--purple);text-decoration:none;transition:color .2s;font-weight:500;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--purple)'">$OPENSG</a>
    <a href="https://x.com/Open_Signum" target="_blank" rel="noopener" style="display:flex;align-items:center;color:var(--text2);transition:color .2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text2)'" title="Follow on X">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <a href={appHref} style="display:inline-flex;align-items:center;gap:6px;padding:8px 18px;border-radius:8px;background:var(--green);color:#000;font-size:13px;font-weight:600;text-decoration:none;transition:box-shadow .2s;" onmouseover="this.style.boxShadow='0 0 20px rgba(0,212,170,.3)'" onmouseout="this.style.boxShadow='none'">
      {session ? 'Dashboard' : 'Launch App'}
    </a>
  </div>
  <!-- Mobile hamburger -->
  <button class="mobile-menu-btn" id="mobileMenuBtn" style="display:none;align-items:center;justify-content:center;width:40px;height:40px;background:none;border:1px solid var(--border);border-radius:8px;cursor:pointer;color:var(--text);">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>
</nav>
<!-- Mobile menu -->
<div class="mobile-menu hidden" id="mobileMenu">
  <a href="#features">Features</a>
  <a href="#how-it-works">How It Works</a>
  <a href="/docs">Docs</a>
  <a href="#roadmap">Roadmap</a>
  <a href="#token" style="color:var(--purple) !important;">$OPENSG</a>
  <a href="https://x.com/Open_Signum" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:8px;">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    Follow on X
  </a>
  <a href={appHref} style="margin-top:8px;text-align:center;padding:12px;border-radius:8px;background:var(--green);color:#000 !important;font-weight:600;">
    {session ? 'Dashboard' : 'Launch App'}
  </a>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════════════════════════════ -->
<section class="hero-section" style="position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:120px 28px 60px;overflow:hidden;">
  <!-- Background effects -->
  <div class="hero-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="particles" id="particles"></div>

  <!-- Content -->
  <div style="position:relative;text-align:center;max-width:860px;z-index:1;">
    <!-- Badge -->
    <div class="reveal" style="display:inline-flex;align-items:center;gap:8px;padding:6px 16px;border-radius:24px;background:rgba(0,212,170,.06);border:1px solid rgba(0,212,170,.15);margin-bottom:24px;">
      <span style="width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:pulse 2s infinite;"></span>
      <span style="font-size:12px;color:var(--green);font-family:var(--font-mono);letter-spacing:.04em;">v1.0 LIVE — OPEN SOURCE TRADING DASHBOARD</span>
    </div>

    <!-- Heading -->
    <h1 class="hero-h1 reveal hero-glow" style="font-size:52px;font-weight:700;line-height:1.15;margin-bottom:20px;letter-spacing:-.02em;">
      The Future of<br/>
      <span class="gradient-text">Intelligent Trading</span>
    </h1>

    <!-- Subtitle -->
    <p class="reveal reveal-d1 hero-subtitle" style="font-size:18px;color:var(--text2);line-height:1.7;max-width:600px;margin:0 auto 16px;">
      Multi-asset charts, AI-powered trade signals, risk management, and portfolio tracking — all in one futuristic dashboard.
    </p>

    <!-- Terminal line -->
    <div class="reveal reveal-d2" style="margin-bottom:36px;">
      <code class="terminal-line" style="font-family:var(--font-mono);font-size:13px;color:var(--green);padding:8px 16px;background:rgba(0,212,170,.05);border-radius:6px;">
        $ signum analyze --asset BTC --signal buy
      </code>
    </div>

    <!-- CTA buttons -->
    <div class="reveal reveal-d3 cta-buttons" style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
      <a href={appHref} class="cta-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        {session ? 'Go to Dashboard' : 'Connect Wallet & Start'}
      </a>
      <a href="/docs" style="display:inline-flex;align-items:center;gap:8px;padding:16px 32px;border-radius:12px;border:1px solid var(--border2);color:var(--text);font-size:16px;font-weight:500;text-decoration:none;transition:all .2s;background:rgba(255,255,255,.02);" onmouseover="this.style.borderColor='var(--text3)';this.style.background='rgba(255,255,255,.04)'" onmouseout="this.style.borderColor='var(--border2)';this.style.background='rgba(255,255,255,.02)'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        Read Docs
      </a>
    </div>
  </div>

  <!-- Animated chart SVG -->
  <div class="reveal reveal-d4 hero-chart-container" style="position:relative;margin-top:60px;width:100%;max-width:700px;z-index:1;">
    <div style="background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:24px 20px 16px;box-shadow:0 20px 60px rgba(0,0,0,.4);">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding:0 8px;">
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-family:var(--font-mono);font-size:14px;font-weight:700;">BTC/USD</span>
          <span style={`font-family:var(--font-mono);font-size:13px;color:${btcUp?'var(--green)':'var(--red)'};`}>${btcPrice}</span>
          <span style={`font-size:11px;color:${btcUp?'var(--green)':'var(--red)'};padding:2px 8px;border-radius:4px;background:${btcUp?'rgba(0,212,170,.1)':'rgba(255,77,106,.1)'};`}>{btcUp?'+':''}{btcChange.toFixed(2)}%</span>
        </div>
        <div class="hero-chart-tags" style="display:flex;gap:6px;">
          <span style="font-size:10px;color:var(--text3);padding:3px 8px;border-radius:4px;border:1px solid var(--border);">RSI</span>
          <span style="font-size:10px;color:var(--text3);padding:3px 8px;border-radius:4px;border:1px solid var(--border);">MACD</span>
          <span style="font-size:10px;color:var(--green);padding:3px 8px;border-radius:4px;border:1px solid rgba(0,212,170,.3);background:rgba(0,212,170,.05);">BB</span>
        </div>
      </div>
      <svg viewBox="0 0 660 180" style="width:100%;display:block;">
        <!-- Grid lines -->
        <line x1="0" y1="45" x2="660" y2="45" stroke="var(--border)" stroke-width=".5" opacity=".5"/>
        <line x1="0" y1="90" x2="660" y2="90" stroke="var(--border)" stroke-width=".5" opacity=".5"/>
        <line x1="0" y1="135" x2="660" y2="135" stroke="var(--border)" stroke-width=".5" opacity=".5"/>
        <!-- Bollinger bands (real) -->
        {bbUpper && <path d={bbUpper} fill="none" stroke="var(--green)" stroke-width="1" opacity=".2" stroke-dasharray="4,4"/>}
        {bbLower && <path d={bbLower} fill="none" stroke="var(--green)" stroke-width="1" opacity=".2" stroke-dasharray="4,4"/>}
        <!-- EMA 20 (real) -->
        {emaPath && <path d={emaPath} fill="none" stroke="var(--blue)" stroke-width="1" opacity=".3" stroke-dasharray="6,3"/>}
        <!-- Main price line (real BTC 30d closes) -->
        <path class="chart-line" d={chartPath} fill="none" stroke="url(#lineGrad)" stroke-width="2.5" stroke-linecap="round"/>
        <!-- Glow -->
        <path d={chartPath} fill="none" stroke="var(--green)" stroke-width="6" opacity=".1" filter="blur(4px)"/>
        <!-- Pulsing dot at last price -->
        <circle cx="660" cy={lastY} r="4" fill={btcUp?'var(--green)':'var(--red)'}>
          <animate attributeName="r" values="4;6;4" dur="2s" repeatCount="indefinite"/>
          <animate attributeName="opacity" values="1;.5;1" dur="2s" repeatCount="indefinite"/>
        </circle>
        <circle cx="660" cy={lastY} r="12" fill={btcUp?'var(--green)':'var(--red)'} opacity=".15">
          <animate attributeName="r" values="12;20;12" dur="2s" repeatCount="indefinite"/>
          <animate attributeName="opacity" values=".15;0;.15" dur="2s" repeatCount="indefinite"/>
        </circle>
        <defs>
          <linearGradient id="lineGrad" x1="0" y1="0" x2="660" y2="0" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="var(--blue)"/>
            <stop offset="50%" stop-color="var(--green)"/>
            <stop offset="100%" stop-color="var(--green)"/>
          </linearGradient>
        </defs>
      </svg>
      <!-- Bottom tickers (real indicators) -->
      <div style="display:flex;gap:16px;margin-top:12px;padding:8px 8px 0;border-top:1px solid var(--border);">
        <span style="font-family:var(--font-mono);font-size:10px;color:var(--text3);">RSI <span style={`color:${rsi>70?'var(--red)':rsi<30?'var(--green)':'var(--amber)'};`}>{rsi.toFixed(1)}</span></span>
        <span style="font-family:var(--font-mono);font-size:10px;color:var(--text3);">MACD <span style={`color:${macd.hist>=0?'var(--green)':'var(--red)'};`}>{macd.hist>=0?'+':''}{macd.hist.toFixed(2)}</span></span>
        <span style="font-family:var(--font-mono);font-size:10px;color:var(--text3);">VOL <span style="color:var(--text2);">{btcVolume}</span></span>
        <span style="font-family:var(--font-mono);font-size:10px;color:var(--text3);">EMA20 <span style="color:var(--blue);">${formatPrice(ema20val)}</span></span>
      </div>
    </div>
  </div>
</section>

