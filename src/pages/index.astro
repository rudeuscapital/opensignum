<!-- ═══════════════════════════════════════════════════════════════════════════
     CLIENT SCRIPTS — scroll reveal, particles
     ═══════════════════════════════════════════════════════════════════════════ -->
<script>
  // Scroll-reveal observer
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // Trigger chart-line animation on visibility
  const chartIO = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
  }, { threshold: 0.3 });
  document.querySelectorAll('.chart-line').forEach(el => chartIO.observe(el));

  // Generate floating particles
  const pc = document.getElementById('particles');
  if (pc) {
    for (let i = 0; i < 30; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.left = Math.random() * 100 + '%';
      p.style.bottom = '-10px';
      p.style.animationDuration = (8 + Math.random() * 12) + 's';
      p.style.animationDelay = (Math.random() * 10) + 's';
      p.style.width = p.style.height = (1 + Math.random() * 2) + 'px';
      pc.appendChild(p);
    }
  }

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobileMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
    // Close on link click
    mobileMenu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => mobileMenu.classList.add('hidden'));
    });
  }

  // Navbar scroll effect
  const nav = document.querySelector('nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        (nav as HTMLElement).style.borderBottomColor = 'rgba(30,42,54,.9)';
        (nav as HTMLElement).style.background = 'rgba(8,12,16,.88)';
      } else {
        (nav as HTMLElement).style.borderBottomColor = 'rgba(30,42,54,.6)';
        (nav as HTMLElement).style.background = 'rgba(8,12,16,.75)';
      }
    }, { passive: true });
  }
</script>
</Base>
